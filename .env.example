DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

# Choose your default LLM provider: openai | ollama | anthropic
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=glm-5.1:cloud
#OLLAMA_MODEL=kimi-k2-thinking:cloud